{
  "name": "attestpay",
  "version": "0.1.0",
  "private": true,
  "description": "Policy-controlled USDC treasury agent on Arc.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "circle:generate-secret": "tsx scripts/circle/generate-entity-secret.ts",
    "circle:register-secret": "node --env-file=.env.local --import=tsx scripts/circle/register-entity-secret.ts",
    "circle:create-wallet": "node --env-file=.env.local --import=tsx scripts/circle/create-treasury-wallet.ts",
    "circle:create-recipient": "node --env-file=.env.local --import=tsx scripts/circle/create-test-recipient.ts",
    "circle:balances": "node --env-file=.env.local --import=tsx src/interfaces/cli/show-treasury-balances.ts",
    "circle:send-test": "node --env-file=.env.local --import=tsx src/interfaces/cli/send-test-transfer.ts",
    "circle:send-memo-test": "node --env-file=.env.local --import=tsx src/interfaces/cli/send-test-memo-transfer.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.8.0",
    "viem": "^2.55.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}
