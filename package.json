{
  "name": "attestpay",
  "version": "0.1.0",
  "private": true,
  "description": "Policy-controlled USDC treasury agent on Arc.",
  "type": "module",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "test:contract": "hardhat test solidity",
    "test:all": "npm run test && npm run test:contract",
    "app:start": "node --import=tsx src/interfaces/http/start-payment-workflow.server.ts",
    "app:seed": "node --import=tsx scripts/seed-demo-workflows.ts",
    "contract:compile": "hardhat compile",
    "circle:generate-secret": "tsx scripts/circle/generate-entity-secret.ts",
    "circle:register-secret": "node --env-file=.env.local --import=tsx scripts/circle/register-entity-secret.ts",
    "circle:create-wallet": "node --env-file=.env.local --import=tsx scripts/circle/create-treasury-wallet.ts",
    "circle:create-recipient": "node --env-file=.env.local --import=tsx scripts/circle/create-test-recipient.ts",
    "circle:create-authorizer": "node --env-file=.env.local --import=tsx scripts/circle/create-vault-authorizer.ts",
    "circle:balances": "node --env-file=.env.local --import=tsx src/interfaces/cli/show-treasury-balances.ts",
    "circle:send-test": "node --env-file=.env.local --import=tsx src/interfaces/cli/send-test-transfer.ts",
    "circle:send-memo-test": "node --env-file=.env.local --import=tsx src/interfaces/cli/send-test-memo-transfer.ts",
    "vault:approve-recipient": "node --env-file=.env.local --import=tsx src/interfaces/cli/approve-test-vault-recipient.ts",
    "vault:status": "node --env-file=.env.local --import=tsx src/interfaces/cli/show-vault-status.ts",
    "vault:fund": "node --env-file=.env.local --import=tsx src/interfaces/cli/fund-test-vault.ts",
    "vault:send-test": "node --env-file=.env.local --import=tsx src/interfaces/cli/send-test-vault-payment.ts",
    "contract:deploy-vault": "npm run contract:compile && node --env-file=.env.local --import=tsx scripts/contracts/deploy-attestpay-vault.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.8.0",
    "@circle-fin/smart-contract-platform": "^10.8.0",
    "@openzeppelin/contracts": "^5.6.1",
    "viem": "^2.55.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "forge-std": "github:foundry-rs/forge-std#v1.9.7",
    "hardhat": "^3.11.0",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "hardhat": {
      "adm-zip": "0.6.0"
    }
  }
}
